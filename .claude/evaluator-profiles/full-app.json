{
  "type": "full-app",
  "name": "Full App Evaluator (FE+BE)",
  "method": "playwright-full",
  "pass_threshold": 7,
  "tools": ["playwright-full", "api-test", "llm-review"],
  "scoring": {
    "completeness": { "weight": 8, "description": "All PRD features implemented end-to-end" },
    "clarity": { "weight": 3, "description": "UI intuitive, API responses clear" },
    "visual_quality": { "weight": 6, "description": "Visual coherence, polish" },
    "ux_accessibility": { "weight": 7, "description": "Usable, accessible, responsive" },
    "design_fidelity": { "weight": 8, "description": "Matches design if design mode != skip" },
    "functionality": { "weight": 10, "description": "Features work end-to-end, CRUD, auth flow" },
    "security": { "weight": 10, "description": "Auth, permissions, input validation, OWASP basics" },
    "performance": { "weight": 8, "description": "Load time, query efficiency, no memory leaks" },
    "testability": { "weight": 5, "description": "Code testable, API documented" }
  },
  "playwright_tests": [
    "All pages load without errors",
    "Auth flow: login → dashboard → logout",
    "Permission boundary: role A cannot access role B resources",
    "CRUD operations via UI persist to database",
    "API endpoints return correct status codes",
    "Form validation prevents invalid submissions",
    "Error states display meaningful messages",
    "Responsive layout (mobile + desktop)"
  ],
  "mandatory_tests": {
    "auth_flow": "login/logout/unauthorized redirect",
    "permission_boundary": "role-based access control verified",
    "data_persistence": "create/read/update/delete via UI → DB"
  },
  "stack": {
    "framework": "Next.js (App Router)",
    "hosting": "Cloudflare Workers / Pages",
    "database": "Cloudflare D1",
    "auth": "better-auth",
    "ui": "shadcn/ui + Tailwind"
  }
}
